{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sketch-studios-website",
  "compatibility_date": "2025-09-27",
  "pages_build_output_dir": ".",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "SKETCH_KV",
      "id": "sketches_production",
      "preview_id": "sketches_preview"
    }
  ]
}
