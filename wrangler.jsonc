{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sketch-studios-website",
  "main": "src/worker.js",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "SKETCH_KV",
      "id": "sketches_production",
      "preview_id": "sketches_preview"
    }
  ]
}
